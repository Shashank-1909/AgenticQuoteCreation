# =============================================================================
# SECRETS & CREDENTIALS — NEVER COMMIT
# =============================================================================
.env
.env.local
.env.production
.env.*.local

# Salesforce OAuth tokens (auto-generated by auth.py)
auth.json
token.txt

# Google service account key files
*.json
# Exception: allow package.json and package-lock.json in frontend
!rca-agentic-frontend/package.json
!rca-agentic-frontend/package-lock.json
!rca-agentic-frontend/*/package.json

# =============================================================================
# PYTHON BACKEND
# =============================================================================
rca-agentic-backend/venv/
rca-agentic-backend/__pycache__/
rca-agentic-backend/**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Log & scratch files
rca-agentic-backend/logs.txt
rca-agentic-backend/out_backend.txt
rca-agentic-backend/adk2.0.txt
rca-agentic-backend/ui.txt

# =============================================================================
# NODE / REACT FRONTEND
# =============================================================================
rca-agentic-frontend/node_modules/
rca-agentic-frontend/dist/
rca-agentic-frontend/.vite/

# =============================================================================
# GENERAL
# =============================================================================
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/settings.json
